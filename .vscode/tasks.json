{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe générer le fichier actif",
            "command": "C:\\Strawberry\\c\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/Code/main.c",
                "${workspaceFolder}/Code/fonctions.c",
                "-I${workspaceFolder}/Code",
                "-o",
                "${workspaceFolder}/Code/main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}/Code"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compile main.c et fonctions.c ensemble pour corriger les undefined references"
        }
    ]
}